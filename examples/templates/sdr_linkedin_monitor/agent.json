  "goal": {
    "id": "sdr-linkedin-monitor",
    "name": "SDR LinkedIn Monitor",
    "description": "Monitor LinkedIn for 'I'm hiring' and 'Just started a new role' posts from VP of Engineering and CTO titles at Series B+ companies, look up verified corporate emails, draft a highly personalized cold email for each, and queue up to 50 per day for SDR review.",
    "status": "draft",
    "success_criteria": [
      {
        "id": "sc-signal-detection",
        "description": "Finds qualifying LinkedIn posts matching target titles and company stage filters",
        "metric": "qualified_leads_found",
        "target": ">=1",
        "weight": 0.25,
        "met": false
      },
      {
        "id": "sc-email-lookup",
        "description": "Attempts corporate email lookup for every qualified lead",
        "metric": "email_lookup_attempted",
        "target": "true",
        "weight": 0.20,
        "met": false
      },
      {
        "id": "sc-personalization",
        "description": "Every drafted email references a specific verified detail about the lead's company",
        "metric": "emails_personalized",
        "target": "true",
        "weight": 0.30,
        "met": false
      },
      {
        "id": "sc-queue-delivered",
        "description": "User receives a downloadable HTML report with all drafted emails",
        "metric": "queue_delivered",
        "target": "true",
        "weight": 0.25,
        "met": false
      }
    ],
    "constraints": [
      {
        "id": "c-no-fabrication",
        "description": "Never fabricate leads, email addresses, or company details — only report what was found from real sources",
        "constraint_type": "hard",
        "category": "quality",
        "check": ""
      },
      {
        "id": "c-quota-cap",
        "description": "Respect the daily quota — never exceed 50 emails per run",
        "constraint_type": "hard",
        "category": "scope",
        "check": ""
      },
      {
        "id": "c-no-send",
        "description": "Never send any email — only draft for human review",
        "constraint_type": "hard",
        "category": "safety",
        "check": ""
      },
      {
        "id": "c-professional-tone",
        "description": "All drafted emails must be professional, genuine, and under 120 words",
